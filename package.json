{
  "name": "mesnew",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n WEB,API -c green,cyan \"vite\" \"tsx watch src/server/index.ts\"",
    "dev:web": "vite",
    "dev:api": "tsx watch --env-file=.env src/server/index.ts",
    "build": "vite build && tsup",
    "deploy": "npm run build && rsync -a --delete dist/index.html /var/www/mesnew/dist/ && rsync -a --delete dist/assets/ /var/www/mesnew/dist/assets/",
    "start": "node --env-file=.env dist/server/index.js",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "lint": "eslint ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "mysql2": "^3.21.0",
    "prisma": "^6.19.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^7.3.2"
  }
}
